# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Path to the GGUF model file (e.g. mistral-7b-instruct-v0.2.Q4_K_M.gguf)
GGUF_MODEL_PATH=/path/to/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# Path to the category Excel file (columns: Category, Category_Code, Term)
CATEGORY_FILE=/path/to/data/SPSS_Category_Concepts.xlsx

# Path to the intent Excel file (columns: ID, Email, Intent, Intent_Code, Method, ...)
INTENT_FILE=/path/to/data/Email_Intents.xlsx

# SQL Server connection settings
SQL_SERVER=your-sql-server-hostname
SQL_DATABASE=EMAIL
SQL_TABLE=[dbo].[Original_Email]

# Set SQL_TRUSTED=true for Windows Authentication (Trusted_Connection)
# Set SQL_TRUSTED=false to use SQL Server authentication (SQL_UID/SQL_PWD)
SQL_TRUSTED=true
SQL_UID=
SQL_PWD=

# Prediction behaviour
BATCH_SIZE=10
DRY_RUN=false

# LLM settings
N_GPU_LAYERS=0
N_CTX=4096
MAX_TOKENS=100
TEMPERATURE=0.05
